<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Jukebox.Launcher.ViewModels"
        x:DataType="vm:AboutViewModel"
        x:Class="Jukebox.Launcher.Views.AboutWindow"
        Title="About Jukebox"
        Width="320"
        Height="200"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="24" Spacing="12">
        <TextBlock AutomationProperties.AutomationId="about-title"
                   Text="Jukebox"
                   FontSize="20"
                   FontWeight="Bold" />

        <TextBlock AutomationProperties.AutomationId="about-version"
                   Text="{Binding VersionDisplay}" />

        <TextBlock AutomationProperties.AutomationId="about-tagline"
                   Text="Self-hosted media server"
                   Opacity="0.7" />

        <Button AutomationProperties.AutomationId="about-close"
                Content="Close"
                HorizontalAlignment="Right"
                Click="OnCloseClicked" />
    </StackPanel>

</Window>
