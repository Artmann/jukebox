<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Jukebox.Launcher.ViewModels"
        x:DataType="vm:AboutViewModel"
        x:Class="Jukebox.Launcher.Views.AboutWindow"
        Title="About Jukebox"
        Width="360"
        Height="300"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="24" Spacing="12">
        <TextBlock AutomationProperties.AutomationId="about-title"
                   Text="Jukebox"
                   FontSize="20"
                   FontWeight="Bold" />

        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0"
                       AutomationProperties.AutomationId="about-launcher-installed"
                       Text="{Binding LauncherInstalledDisplay}" />

            <TextBlock Grid.Row="0" Grid.Column="1"
                       Margin="12,0,0,0"
                       AutomationProperties.AutomationId="about-launcher-latest"
                       Text="{Binding LauncherLatestDisplay}"
                       Opacity="0.6" />

            <TextBlock Grid.Row="1" Grid.Column="0"
                       Margin="0,4,0,0"
                       AutomationProperties.AutomationId="about-server-installed"
                       Text="{Binding ServerInstalledDisplay}" />

            <TextBlock Grid.Row="1" Grid.Column="1"
                       Margin="12,4,0,0"
                       AutomationProperties.AutomationId="about-server-latest"
                       Text="{Binding ServerLatestDisplay}"
                       Opacity="0.6" />
        </Grid>

        <TextBlock AutomationProperties.AutomationId="about-status"
                   Text="{Binding StatusDisplay}"
                   TextWrapping="Wrap"
                   Opacity="0.7" />

        <TextBlock AutomationProperties.AutomationId="about-server-state"
                   Text="{Binding ServerStateDisplay}"
                   TextWrapping="Wrap"
                   Opacity="0.7" />

        <TextBlock AutomationProperties.AutomationId="about-tagline"
                   Text="Self-hosted media server"
                   Opacity="0.7" />

        <Button AutomationProperties.AutomationId="about-close"
                Content="Close"
                HorizontalAlignment="Right"
                Click="OnCloseClicked" />
    </StackPanel>

</Window>
