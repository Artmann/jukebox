{
  "name": "jukebox-media-server",
  "version": "0.5.1",
  "description": "Self-hosted media server with a Netflix-style interface for browsing and streaming your personal movie and TV show collection.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Artmann/jukebox.git"
  },
  "homepage": "https://github.com/Artmann/jukebox#readme",
  "bugs": {
    "url": "https://github.com/Artmann/jukebox/issues"
  },
  "type": "module",
  "bin": {
    "jukebox-media-server": "./bin/jukebox-media-server.js"
  },
  "files": [
    "dist/",
    "bin/",
    "drizzle/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "media-server",
    "movies",
    "netflix",
    "plex-alternative",
    "self-hosted",
    "streaming",
    "tv-shows"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts",
    "build:client": "vite build",
    "build:executable": "tsx scripts/build-executable.ts",
    "build:server": "rolldown -c rolldown.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "tsx watch src/index.ts",
    "format": "prettier --write .",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prepublishOnly": "npm run build",
    "scan": "tsx src/scripts/scan.ts",
    "start": "NODE_ENV=production node dist/server/index.js",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.5.0",
    "cmdk": "^1.1.1",
    "dayjs": "^1.11.20",
    "dotenv": "^17.2.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "4.54.0",
    "@rollup/rollup-darwin-x64": "4.54.0",
    "@rollup/rollup-linux-arm64-gnu": "4.54.0",
    "@rollup/rollup-linux-arm64-musl": "4.54.0",
    "@rollup/rollup-linux-x64-gnu": "4.54.0",
    "@rollup/rollup-linux-x64-musl": "4.54.0",
    "@rollup/rollup-win32-arm64-msvc": "4.54.0",
    "@rollup/rollup-win32-x64-msvc": "4.54.0",
    "@tailwindcss/oxide-darwin-arm64": "4.1.18",
    "@tailwindcss/oxide-darwin-x64": "4.1.18",
    "@tailwindcss/oxide-linux-arm64-gnu": "4.1.18",
    "@tailwindcss/oxide-linux-arm64-musl": "4.1.18",
    "@tailwindcss/oxide-linux-x64-gnu": "4.1.18",
    "@tailwindcss/oxide-linux-x64-musl": "4.1.18",
    "@tailwindcss/oxide-win32-arm64-msvc": "4.1.18",
    "@tailwindcss/oxide-win32-x64-msvc": "4.1.18",
    "lightningcss-darwin-arm64": "1.30.2",
    "lightningcss-darwin-x64": "1.30.2",
    "lightningcss-linux-arm64-gnu": "1.30.2",
    "lightningcss-linux-arm64-musl": "1.30.2",
    "lightningcss-linux-x64-gnu": "1.30.2",
    "lightningcss-linux-x64-musl": "1.30.2",
    "lightningcss-win32-arm64-msvc": "1.30.2",
    "lightningcss-win32-x64-msvc": "1.30.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hono/node-server": "^1.19.14",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.15",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "hono": "^4.11.3",
    "jsdom": "^27.4.0",
    "lucide-react": "^0.545.0",
    "prettier": "^3.7.4",
    "react": "^19",
    "react-dom": "^19",
    "react-hotkeys-hook": "^5.2.4",
    "react-router-dom": "^7.11.0",
    "rolldown": "^1.0.0-rc.15",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "tiny-invariant": "^1.3.3",
    "tiny-typescript-logger": "^3.2.3",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "video.js": "^8.23.4",
    "vite": "^7.3.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.16"
  }
}
